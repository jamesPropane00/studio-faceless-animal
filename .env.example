# ============================================================
#  FACELESS ANIMAL STUDIOS — ENVIRONMENT VARIABLES
#  .env.example
#
#  Copy this file and fill in your values.
#  DO NOT commit real credentials. Use Replit's Secrets tab
#  (or your deployment platform's env var system) to set these.
#
#  HOW TO FIND THESE VALUES:
#    1. Create a project at https://supabase.com
#    2. Go to Project Settings → API
#    3. Copy "Project URL" → SUPABASE_URL
#    4. Copy "anon public" key → SUPABASE_ANON_KEY
#       (This key is safe to expose in the browser — Supabase
#        uses Row Level Security for access control, not key secrecy.)
#
#  HOW TO SET IN REPLIT:
#    Open the Secrets tab (lock icon in the sidebar) and add:
#      SUPABASE_URL       → your project URL
#      SUPABASE_ANON_KEY  → your anon public key
#    Then restart the server — assets/js/env.js is auto-generated.
#
#  HOW TO SET FOR CLOUDFLARE PAGES:
#    Go to Pages project → Settings → Environment variables
#    Add both variables under Production and Preview environments.
#    Set build command to: node scripts/generate-env.js
# ============================================================

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
